---
// src/components/overrides/Hero.astro
// TomikCRM — Premium Hero with animated grid + particle glow
import { brand } from '../../config/brand.ts';

type HeroAction = {
  link: string;
  text: string;
  variant?: 'primary' | 'secondary' | 'minimal';
  icon?: { type: string; name: string };
};

const entry = (Astro.locals as any).starlightRoute?.entry;
const hero = entry?.data?.hero;
const heroTitle = hero?.title ?? entry?.data?.title;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

{hero ? (
  <div class="nexus-hero">
    {/* Layered background effects */}
    <div class="nexus-hero__grid" aria-hidden="true"></div>
    <div class="nexus-hero__glow" aria-hidden="true"></div>
    <div class="nexus-hero__glow-secondary" aria-hidden="true"></div>
    <div class="nexus-hero__particles" aria-hidden="true"></div>
    <div class="nexus-hero__vignette" aria-hidden="true"></div>

    <div class="nexus-hero__content">

      <div class="nexus-hero__badge">
        <span class="nexus-hero__badge-dot"></span>
        <span>{brand.name}</span>
        <span class="nexus-hero__badge-version">{brand.version}</span>
      </div>

      <h1 class="nexus-hero__title">{heroTitle}</h1>

      {hero.tagline && (
        <p class="nexus-hero__tagline">{hero.tagline}</p>
      )}

      {hero.actions && hero.actions.length > 0 && (
        <div class="nexus-hero__actions">
          {(hero.actions as HeroAction[]).map((action) => (
            <a
              href={action.link.startsWith('http') ? action.link : `${base}${action.link}`}
              class:list={[
                'nexus-hero__action',
                action.variant === 'primary'
                  ? 'nexus-hero__action--primary'
                  : 'nexus-hero__action--secondary',
              ]}
              {...action.link.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
            >
              {action.text}
              {action.icon?.name === 'right-arrow' && <span aria-hidden="true"> →</span>}
            </a>
          ))}
        </div>
      )}

      <div class="nexus-hero__meta">
        <span>Documentação técnica</span>
        <span class="nexus-hero__meta-dot">·</span>
        <span>CRM com IA</span>
        <span class="nexus-hero__meta-dot">·</span>
        <span>Operação comercial inteligente</span>
      </div>

    </div>

    {/* Bottom fade into page background */}
    <div class="nexus-hero__fade" aria-hidden="true"></div>
  </div>
) : null}

<style>
  /* ── Hero Container ── */
  .nexus-hero {
    position: relative;
    padding: 6rem 2rem 5rem;
    text-align: center;
    overflow: hidden;
    min-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Animated Grid Pattern ── */
  .nexus-hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(124, 141, 82, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(124, 141, 82, 0.08) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 20%, transparent 70%);
    animation: gridPulse 8s ease-in-out infinite;
  }

  @keyframes gridPulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  /* ── Primary Glow — green, top center ── */
  .nexus-hero__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 60% 50% at 50% 0%,
      rgba(124, 141, 82, 0.2) 0%,
      rgba(124, 141, 82, 0.08) 30%,
      transparent 65%
    );
    pointer-events: none;
  }

  /* ── Secondary Glow — purple accent from #252129, subtle ── */
  .nexus-hero__glow-secondary {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 40% 40% at 75% 20%,
      rgba(37, 33, 41, 0.4) 0%,
      transparent 60%
    );
    pointer-events: none;
  }

  /* ── Floating Particles (CSS-only) ── */
  .nexus-hero__particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .nexus-hero__particles::before,
  .nexus-hero__particles::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    background: rgba(124, 141, 82, 0.35);
    animation: float 12s ease-in-out infinite;
  }

  .nexus-hero__particles::before {
    width: 3px;
    height: 3px;
    top: 30%;
    left: 20%;
    box-shadow:
      120px -40px 0 rgba(160, 176, 120, 0.3),
      280px 60px 0 rgba(124, 141, 82, 0.25),
      400px -20px 0 rgba(144, 163, 98, 0.2),
      520px 40px 0 rgba(160, 176, 120, 0.35),
      650px -50px 0 rgba(124, 141, 82, 0.15),
      180px 80px 0 rgba(144, 163, 98, 0.3),
      350px 100px 0 rgba(124, 141, 82, 0.2),
      500px 120px 0 rgba(160, 176, 120, 0.25);
  }

  .nexus-hero__particles::after {
    width: 2px;
    height: 2px;
    top: 50%;
    left: 35%;
    animation-delay: -6s;
    animation-duration: 16s;
    box-shadow:
      80px -60px 0 rgba(124, 141, 82, 0.2),
      200px 30px 0 rgba(160, 176, 120, 0.3),
      340px -40px 0 rgba(144, 163, 98, 0.15),
      460px 50px 0 rgba(124, 141, 82, 0.25),
      580px -30px 0 rgba(160, 176, 120, 0.2),
      150px 70px 0 rgba(144, 163, 98, 0.35);
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) translateX(0); }
    33% { transform: translateY(-12px) translateX(6px); }
    66% { transform: translateY(8px) translateX(-4px); }
  }

  /* ── Vignette — darkens edges ── */
  .nexus-hero__vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 100% 100% at 50% 50%,
      transparent 40%,
      rgba(18, 23, 14, 0.6) 100%
    );
    pointer-events: none;
  }

  /* ── Bottom Fade — smooth transition to page ── */
  .nexus-hero__fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent, var(--bg));
    pointer-events: none;
  }

  /* ── Content ── */
  .nexus-hero__content {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
  }

  /* ── Badge ── */
  .nexus-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    background-color: rgba(124, 141, 82, 0.1);
    border: 1px solid rgba(124, 141, 82, 0.25);
    border-radius: 100px;
    font-size: 0.8125rem;
    font-family: 'Inter', sans-serif;
    color: #A0B478; /* +25% tint from brand scale */
    margin-bottom: 2rem;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .nexus-hero__badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: #7C8D52;
    box-shadow: 0 0 8px rgba(124, 141, 82, 0.6);
    animation: dotPulse 3s ease-in-out infinite;
  }

  @keyframes dotPulse {
    0%, 100% { box-shadow: 0 0 8px rgba(124, 141, 82, 0.6); }
    50% { box-shadow: 0 0 16px rgba(124, 141, 82, 0.9); }
  }

  .nexus-hero__badge-version {
    color: #90A362; /* muted from brand */
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
  }

  /* ── Title ── */
  .nexus-hero__title {
    font-family: 'Exo 2', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.035em;
    color: #FFFFFF;
    margin: 0 0 1.5rem;
    text-shadow: 0 2px 24px rgba(18, 23, 14, 0.5);
  }

  /* ── Tagline ── */
  .nexus-hero__tagline {
    font-family: 'Inter', sans-serif;
    font-size: 1.125rem;
    color: #90A362; /* muted — stands out better than gray on this bg */
    line-height: 1.65;
    margin: 0 auto 2.75rem;
    max-width: 540px;
  }

  /* ── Action Buttons ── */
  .nexus-hero__actions {
    display: flex;
    gap: 0.875rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.75rem;
  }

  .nexus-hero__action {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.7rem 1.5rem;
    border-radius: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
    position: relative;
  }

  /* Primary — solid accent with glow hover */
  .nexus-hero__action--primary {
    background-color: #7C8D52;
    color: #FFFFFF;
    box-shadow: 0 2px 8px rgba(124, 141, 82, 0.2);
  }

  .nexus-hero__action--primary:hover {
    background-color: #688451; /* +37.5% shade */
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(124, 141, 82, 0.35);
  }

  .nexus-hero__action--primary:active {
    transform: translateY(0);
  }

  /* Secondary — glass effect with border */
  .nexus-hero__action--secondary {
    background-color: rgba(28, 33, 24, 0.6);
    color: #FFFFFF;
    border: 1px solid rgba(46, 59, 36, 0.8);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .nexus-hero__action--secondary:hover {
    border-color: rgba(124, 141, 82, 0.5);
    background-color: rgba(28, 33, 24, 0.8);
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(124, 141, 82, 0.1);
  }

  /* ── Meta Tags ── */
  .nexus-hero__meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    color: #4B603B; /* +25% shade of bg — subtle but visible */
    flex-wrap: wrap;
  }

  .nexus-hero__meta-dot {
    color: #2E3B24; /* border color as dot */
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .nexus-hero {
      padding: 4rem 1.25rem 3.5rem;
      min-height: 400px;
    }

    .nexus-hero__grid {
      background-size: 32px 32px;
    }

    .nexus-hero__actions {
      flex-direction: column;
      align-items: center;
    }

    .nexus-hero__action {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .nexus-hero__grid,
    .nexus-hero__particles::before,
    .nexus-hero__particles::after,
    .nexus-hero__badge-dot {
      animation: none;
    }
  }
</style>